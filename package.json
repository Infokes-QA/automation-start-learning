{
  "name": "playwright-bdd-login-template",
  "version": "1.0.0",
  "description": "Minimal Playwright BDD template for login automation",
  "main": "index.js",
  "scripts": {
    "bdd:gen": "bddgen test",
    "test": "npm run bdd:gen && playwright test",
    "test:headed": "npm run test -- --project=chromium --headed",
    "test:headed:tag": "npm run test -- --grep @pendaftaranPasien --project=chromium --headed",
    "test:list": "npm run bdd:gen && playwright test --project=chromium --list",
    "test:report": "playwright show-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Infokes-QA/automation-research-ts.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Infokes-QA/automation-research-ts/issues"
  },
  "homepage": "https://github.com/Infokes-QA/automation-research-ts#readme",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "dotenv": "^16.4.5",
    "playwright-bdd": "^8.0.0"
  }
}
